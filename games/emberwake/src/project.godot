; Emberwake — engine contract §1 (project layout) / §6 (input actions).
; Window size + filter from gdd/style-bible.json (640x360, nearest).
; m8/battle/speed_stat binds the turn-order stat to the game's stat model
; (content id lives in config data, not in .gd code; ContentDB validates it).
; m8/run/* bind GDD/decision-log run config the same way: party_size from
; gdd.json party.size, start_gold from decision G-004 (03b flagged addition).

config_version=5

[application]

config/name="Emberwake"
run/main_scene="res://scenes/title.tscn"
config/features=PackedStringArray("4.7")

[autoload]

ContentDB="*res://autoload/content_db.gd"
Game="*res://autoload/game.gd"
Rng="*res://autoload/rng.gd"
M8Input="*res://autoload/m8_input.gd"
M8Debug="*res://autoload/m8_debug.gd"

[display]

window/size/viewport_width=640
window/size/viewport_height=360
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"

[m8]

battle/speed_stat="agi"
run/party_size=2
run/start_gold=120

[rendering]

textures/canvas_textures/default_texture_filter=0

[input]

