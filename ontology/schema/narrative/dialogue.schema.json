{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mode8.dev/ontology/narrative/dialogue",
  "title": "Dialogue script collection",
  "description": "games/<title>/content/dialogue.json. Linear scripts (branching belongs to story-graph choice nodes). VN presentation metadata (portraits, positions) tightens at M3.",
  "type": "object",
  "required": ["ontology_version", "domain", "entries"],
  "properties": {
    "ontology_version": {"type": "string"},
    "domain": {"const": "dialogue"},
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "lines"],
        "properties": {
          "id": {"$ref": "https://mode8.dev/ontology/effect-algebra#/$defs/Id"},
          "lines": {
            "type": "array", "minItems": 1,
            "items": {
              "type": "object",
              "required": ["speaker", "text"],
              "properties": {
                "speaker": {"type": "string", "description": "display name; '*' = narrator"},
                "text": {"type": "string", "minLength": 1},
                "portrait": {"type": "string"},
                "emotion": {"type": "string"}
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
