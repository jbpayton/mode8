{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mode8.dev/ontology/entities/encounter",
  "title": "Encounter tables",
  "description": "games/<title>/content/encounters.json. Maps reference tables by id; the engine rolls on entering encounter-enabled tiles.",
  "type": "object",
  "required": ["ontology_version", "domain", "entries"],
  "properties": {
    "ontology_version": {"type": "string"},
    "domain": {"const": "encounters"},
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "steps_per_check", "encounter_chance", "groups"],
        "properties": {
          "id": {"$ref": "https://mode8.dev/ontology/effect-algebra#/$defs/Id"},
          "steps_per_check": {"type": "integer", "minimum": 1},
          "encounter_chance": {"type": "number", "exclusiveMinimum": 0, "maximum": 1},
          "groups": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["weight", "monsters"],
              "properties": {
                "weight": {"type": "number", "exclusiveMinimum": 0},
                "monsters": {
                  "type": "array", "minItems": 1,
                  "items": {"$ref": "https://mode8.dev/ontology/effect-algebra#/$defs/Id"}
                },
                "surprise_chance": {"type": "number", "minimum": 0, "maximum": 1}
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
